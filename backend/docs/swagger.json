{
  "openapi": "3.0.0",
  "info": {
    "title": "PixScribeIA API",
    "version": "1.0.0",
    "description": "Documentation de l'API PixScribeIA"
  },
  "servers": [
    { "url": "http://localhost:5000" }
  ],
  "tags": [
    { "name": "Auth", "description": "Gestion des utilisateurs" },
    { "name": "Requetes", "description": "Gestion des requêtes et des images" },
    { "name": "Historique", "description": "Gestion de l'historique utilisateur" }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Inscription d'un utilisateur",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "email", "password"],
                "properties": {
                  "username": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "✅ Utilisateur créé" },
          "500": { "description": "❌ Erreur lors de la création du compte" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Connexion d'un utilisateur",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "✅ Connexion réussie" },
          "401": { "description": "❌ Identifiants invalides" }
        }
      }
    },
    "/api/requete": {
      "post": {
        "tags": ["Requetes"],
        "summary": "Créer une nouvelle requête",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": { "type": "string", "example": "Bearer <token>" },
            "description": "Token JWT pour authentification"
          }
        ],
        "responses": {
          "201": { "description": "✅ Requête créée" },
          "401": { "description": "❌ Token manquant ou invalide" },
          "500": { "description": "❌ Erreur serveur" }
        }
      }
    },
    "/api/requete/upload/{requeteId}": {
      "post": {
        "tags": ["Requetes"],
        "summary": "Uploader une image liée à une requête",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": { "type": "string", "example": "Bearer <token>" }
          },
          {
            "name": "requeteId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "ID de la requête"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "image": {
                    "type": "string",
                    "format": "binary",
                    "description": "Image à uploader"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "✅ Image uploadée avec succès" },
          "400": { "description": "❌ Aucune image fournie" },
          "404": { "description": "❌ Requête non trouvée" },
          "500": { "description": "❌ Erreur serveur" }
        }
      }
    },
    "/api/requete/{requeteId}": {
      "delete": {
        "tags": ["Requetes"],
        "summary": "Supprimer une requête et ses images",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": { "type": "string", "example": "Bearer <token>" }
          },
          {
            "name": "requeteId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "✅ Requête supprimée" },
          "404": { "description": "❌ Requête introuvable" },
          "500": { "description": "❌ Erreur serveur" }
        }
      }
    },
    "/api/requete/images/user": {
      "delete": {
        "tags": ["Requetes"],
        "summary": "Supprimer toutes les images d'un utilisateur",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": { "type": "string", "example": "Bearer <token>" }
          }
        ],
        "responses": {
          "200": { "description": "✅ Images utilisateur supprimées" },
          "404": { "description": "❌ Aucune image trouvée" },
          "500": { "description": "❌ Erreur serveur" }
        }
      }
    },
    "/api/historique": {
      "get": {
        "tags": ["Historique"],
        "summary": "Récupérer l'historique complet",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": { "type": "string", "example": "Bearer <token>" }
          }
        ],
        "responses": {
          "200": { "description": "✅ Historique récupéré" },
          "401": { "description": "❌ Token manquant ou invalide" },
          "500": { "description": "❌ Erreur serveur" }
        }
      }
    },
    "/api/historique/{id}": {
      "get": {
        "tags": ["Historique"],
        "summary": "Récupérer un historique précis",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": { "type": "string", "example": "Bearer <token>" }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "✅ Historique trouvé" },
          "404": { "description": "❌ Historique introuvable" },
          "500": { "description": "❌ Erreur serveur" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
