# ===============================
# 🌐 FRONTEND CONFIGURATION
# ===============================

# URL de l'API backend vue par le navigateur (localhost car navigateur ≠ Docker)
VITE_API_URL=http://localhost:5000/api

# ===============================
# 🔙 BACKEND CONFIGURATION
# ===============================

# Infos de connexion MySQL pour le backend Node.js (en Docker)
DB_NAME=cours-mia
DB_USER=root
DB_PASSWORD=root
DB_HOST=pixscribe_db
DB_PORT=3306
JWT_SECRET=super_secret_key

# URL pour que le backend appelle l'IA (FastAPI)
FASTAPI_URL=http://pixscribe_ia:8000/api

# ===============================
# 🧠 IA CONFIGURATION (FastAPI)
# ===============================

# Pour éviter les problèmes de buffer Python
PYTHONUNBUFFERED=1
